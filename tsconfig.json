{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    "moduleResolution": "bundler",
    "jsx": "react-jsx",

    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "moduleDetection": "force",

    "allowJs": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,

    "noEmit": true,

    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["src"]
}